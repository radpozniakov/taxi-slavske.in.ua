{% from "nav.njk" import nav %}
<main class="page">
  {{ nav("food") }}
  <section class="food-delivery content">
    <div class="food-delivery__restaurants">
      {% for r in restaurants %}
      <div class="food-delivery__restaurant">
        <picture class="food-delivery__restaurant-picture">
          <source srcset="/assets/img/food/{{ r.slug }}/avif/1100.avif 1100w, /assets/img/food/{{ r.slug }}/avif/800.avif 800w, /assets/img/food/{{ r.slug }}/avif/550.avif 550w, /assets/img/food/{{ r.slug }}/avif/400.avif 400w, /assets/img/food/{{ r.slug }}/avif/320.avif 320w" sizes="calc(100vw - 2 * 16px)" type="image/avif">
          <source srcset="/assets/img/food/{{ r.slug }}/webp/1100.webp 1100w, /assets/img/food/{{ r.slug }}/webp/800.webp 800w, /assets/img/food/{{ r.slug }}/webp/550.webp 550w, /assets/img/food/{{ r.slug }}/webp/400.webp 400w, /assets/img/food/{{ r.slug }}/webp/320.webp 320w" sizes="calc(100vw - 2 * 16px)" type="image/webp">
          <img class="food-delivery__restaurant-photo" src="/assets/img/food/{{ r.slug }}/jpg/1100.jpg" alt="{{ r.alt }}" fetchpriority="high">
        </picture>
        <div class="food-delivery__restaurant-content">
          <h2 class="food-delivery__restaurant-title">{{ r.title }}</h2>
          <ul class="food-delivery__restaurant-info">
            {% if r.rating %}
            <li class="food-delivery__restaurant-info-item"><span>{{ r.rating }}</span> {{ r.ratingSvg | safe }} <span>{{ r.reviews }}</span></li>
            {% endif %}
            {% if r.menu %}
            <li class="food-delivery__restaurant-info-item"><span>Меню: </span><a href="{{ r.menu.href }}">{{ r.menu.label }}</a></li>
            {% endif %}
            <li class="food-delivery__restaurant-info-item"><span>{{ r.hours }}</span></li>
            <li class="food-delivery__restaurant-info-item"><span>Телефон доставки: </span><a href="{{ r.phoneHref }}">{{ r.phone }}</a></li>
          </ul>
          <div class="food-delivery__actions"><a class="action-btn action-btn--no-icon action-btn--active" href="{{ r.phoneHref }}"><span class="action-btn__title">Замовити доставку</span></a></div>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>
</main>
